        xmlns:local="clr-namespace:WarehouseInventory.Desktop"
        mc:Ignorable="d"
        Title="AfterLogin" 
        Height="760" 
        MinWidth="980"
        MinHeight="680"
        Width="1180">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="31*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="1149*"/>
