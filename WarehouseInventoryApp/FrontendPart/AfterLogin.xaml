        <Button Content="" HorizontalAlignment="Left" Margin="16,152,0,0" VerticalAlignment="Top" Height="75" Width="130" Grid.ColumnSpan="3" RenderTransformOrigin="0.638,0.521"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="16,297,0,0" VerticalAlignment="Top" Height="75" Width="130" Grid.ColumnSpan="3" RenderTransformOrigin="0.638,0.521"/>
        <Button Content="" HorizontalAlignment="Left" Margin="16,460,0,0" VerticalAlignment="Top" Height="74" Width="130" Grid.ColumnSpan="3" RenderTransformOrigin="0.638,0.521" Click="Button_Click"/>
        <Image Margin="16,152,1034,517" Source="/63633.png" Stretch="Fill" Grid.ColumnSpan="3"/>
        <Image Margin="16,294,1034,374" Source="/photo_2025-11-06_22-36-59-Photoroom.png" Stretch="Fill" Grid.ColumnSpan="3"/>

    </Grid>
