<Window x:Class="WarehouseInventory.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MaxPovezet"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#D9D9D9"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="YellowBrush" Color="#FFCC00" />
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#4159D8" />
            <GradientStop Offset="1" Color="#8C4AC5" />
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#2E363E" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#2E363E" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.9*" />
            <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,24,0"
                Padding="28"
                CornerRadius="22"
                Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="390"
                        Height="56"
                        HorizontalAlignment="Center"
                        CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#C81DFF" />
                            <GradientStop Offset="1" Color="#1538BF" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="32"
                               FontWeight="Black">
                        <Run Text="Макс" Foreground="#3756CE" />
                        <Run Text="По" Foreground="#D766D9" />
                        <Run Text="Везет" Foreground="#8A48C3" />
                    </TextBlock>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,28,0,0"
                      Height="250"/>

                <TextBlock Grid.Row="2"
                           Margin="0,28,0,0"
                           MaxWidth="480"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           LineHeight="42"
                           TextWrapping="Wrap"
                           Text="От бургеров до гробов довезем всё, что пожелаешь!" />

                <Button Grid.Row="3"
                        Width="200"
                        Height="42"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Background="{StaticResource YellowBrush}"
                        Command="{Binding ShowRegisterCommand}"
                        Content="Создать аккаунт" />
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="32"
                CornerRadius="28"
                Background="#F8F8F8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right"
                            Width="170"
                            Margin="12,0,0,0"
                            Background="#FFCC00"
                            Command="{Binding ShowRegisterCommand}"
                            Content="Регистрация" />
                    <Button DockPanel.Dock="Right"
                            Width="130"
                            Background="#EEF2FF"
                            Command="{Binding ShowLoginCommand}"
                            Content="Вход" />
                </DockPanel>

                <ContentControl Grid.Row="1"
                                Margin="0,24,0,0"
                                Content="{Binding CurrentScreen}" />
            </Grid>
        </Border>
        <Image Margin="50,110,57,349" 
        Source="/truck2.png" 
        Stretch="Fill" 
        RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.085"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
    </Grid>
</Window>
