<Application x:Class="WarehouseInventory.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WarehouseInventory.Desktop.Views"
             xmlns:viewModels="clr-namespace:WarehouseInventory.Desktop.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="0"
                              Height="0"
                              Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:OverviewSectionViewModel}">
            <views:OverviewSectionView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ProductsSectionViewModel}">
            <views:ProductsSectionView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:DocumentsSectionViewModel}">
            <views:DocumentsSectionView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SuppliesSectionViewModel}">
            <views:SuppliesSectionView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ProfileSectionViewModel}">
            <views:ProfileSectionView />
        </DataTemplate>
    </Application.Resources>
</Application>
