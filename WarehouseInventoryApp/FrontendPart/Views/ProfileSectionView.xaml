<UserControl x:Class="WarehouseInventory.Desktop.Views.ProfileSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1040">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock MaxWidth="760"
                           FontSize="34"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Text="{Binding Header}" />
                <TextBlock Margin="0,10,0,0"
                           MaxWidth="920"
                           FontSize="15"
                           Foreground="#667085"
                           TextWrapping="Wrap"
                           Text="{Binding Description}" />
            </StackPanel>

            <WrapPanel Grid.Row="1"
                       Margin="0,18,0,0"
                       VerticalAlignment="Center">
                <Button Width="210"
                        Height="44"
                        Margin="0,0,14,10"
                        Background="#FFCC00"
                        BorderThickness="0"
                        Command="{Binding ToggleEditProfileCommand}"
                        Content="{Binding ToggleEditButtonText}"
                        FontSize="15"
                        FontWeight="SemiBold" />
                <Border Margin="0,0,0,10"
                        Padding="16,11"
                        CornerRadius="16"
                        Background="#F4F7FF">
                    <TextBlock MaxWidth="620"
                               Foreground="#3756CE"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Text="{Binding StatusMessage}" />
                </Border>
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,28,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="2"
                    Margin="0,0,24,0"
                    Padding="26"
                    CornerRadius="28"
                    Background="#FFFFFF">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="24"
                                CornerRadius="24"
                                Background="#F7F9FE">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="112"
                                        Height="112"
                                        CornerRadius="24"
                                        Background="#2E4A75"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top">
                                    <Grid>
                                        <Image Source="{Binding ProfileImagePath}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   Text="{Binding EmployeeId}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0">
                                    <TextBlock FontSize="13"
                                               Foreground="#667085"
                                               Text="ФИО сотрудника" />
                                    <TextBox Margin="0,8,0,0"
                                             FontSize="30"
                                             FontWeight="Bold"
                                             Foreground="#1F2937"
                                             Background="#00FFFFFF"
                                             BorderThickness="0"
                                             TextWrapping="Wrap"
                                             IsEnabled="{Binding IsEditing}"
                                             Text="{Binding EmployeeFullName, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="19"
                                               Foreground="#3756CE"
                                               TextWrapping="Wrap"
                                               Text="{Binding Role}" />

                                    <WrapPanel Margin="0,14,0,0">
                                        <Border Margin="0,0,12,10"
                                                Padding="12,8"
                                                CornerRadius="14"
                                                Background="#EEF3FF">
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="#667085"
                                                           Text="Учетная запись" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentUserName}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,0,10"
                                                Padding="12,8"
                                                CornerRadius="14"
                                                Background="#FFF8D9">
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="#8A6B00"
                                                           Text="Статус аватара" />
                                                <TextBlock Margin="0,4,0,0"
                                                           MaxWidth="190"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#5B4A00"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding AvatarStatusText}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <Button Width="150"
                                            Height="38"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Left"
                                            Background="#E9EDF8"
                                            BorderThickness="0"
                                            Command="{Binding ChooseAvatarCommand}"
                                            Content="Выбрать аватар">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Margin="0,24,0,14"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   Text="Рабочие параметры" />

                        <WrapPanel Grid.Row="2"
                                   ItemWidth="240"
                                   Orientation="Horizontal">
                            <Border Width="240"
                                    Height="152"
                                    Margin="0,0,18,18"
                                    Padding="18"
                                    CornerRadius="22"
                                    Background="#F8FAFF"
                                    BorderBrush="#ECF0F8"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="#667085"
                                               Text="Смена" />
                                    <ScrollViewer Margin="0,10,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBox FontSize="17"
                                                 FontWeight="SemiBold"
                                                 Background="#00FFFFFF"
                                                 BorderThickness="0"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Text="{Binding Shift, UpdateSourceTrigger=PropertyChanged}" />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Width="240"
                                    Height="152"
                                    Margin="0,0,18,18"
                                    Padding="18"
                                    CornerRadius="22"
                                    Background="#F8FAFF"
                                    BorderBrush="#ECF0F8"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="#667085"
                                               Text="Зона ответственности" />
                                    <ScrollViewer Margin="0,10,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBox FontSize="17"
                                                 FontWeight="SemiBold"
                                                 Background="#00FFFFFF"
                                                 BorderThickness="0"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Text="{Binding WarehouseZone, UpdateSourceTrigger=PropertyChanged}" />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Width="240"
                                    Height="132"
                                    Margin="0,0,18,18"
                                    Padding="18"
                                    CornerRadius="22"
                                    Background="#F8FAFF"
                                    BorderBrush="#ECF0F8"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="#667085"
                                               Text="Последний вход" />
                                    <ScrollViewer Margin="0,10,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding LastLogin}" />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Width="240"
                                    Height="132"
                                    Margin="0,0,18,18"
                                    Padding="18"
                                    CornerRadius="22"
                                    Background="#F8FAFF"
                                    BorderBrush="#ECF0F8"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="#667085"
                                               Text="Права доступа" />
                                    <ScrollViewer Margin="0,10,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock FontSize="17"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding AccessLevel}" />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Padding="22"
                    CornerRadius="28"
                    Background="#FFFFFF">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Text="Короткая статистика смены" />

                    <Border Margin="0,18,0,14"
                            Padding="18"
                            CornerRadius="22"
                            Background="#F6F8FD">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="#667085"
                                           TextWrapping="Wrap"
                                           Text="Проверок и задач сегодня" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Text="{Binding TasksCompletedToday}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Width="50"
                                    Height="50"
                                    CornerRadius="16"
                                    Background="#EAF0FF">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#3756CE"
                                           Text="1" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,14"
                            Padding="18"
                            CornerRadius="22"
                            Background="#F6F8FD">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="#667085"
                                           TextWrapping="Wrap"
                                           Text="Точность инвентаризации" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Text="{Binding InventoryAccuracyPercent}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Width="50"
                                    Height="50"
                                    CornerRadius="16"
                                    Background="#E9F7EE">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#1D7A46"
                                           Text="%" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Padding="18"
                            CornerRadius="22"
                            Background="#F6F8FD">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="#667085"
                                           TextWrapping="Wrap"
                                           Text="Товаров под ответственностью" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Text="{Binding TotalProducts}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Width="50"
                                    Height="50"
                                    CornerRadius="16"
                                    Background="#FFF2CC">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#9A6A00"
                                           Text="∑" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Padding="22"
                    CornerRadius="28"
                    Background="#FFFFFF">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Text="Рабочие заметки" />
                    <Border Margin="0,16,0,0"
                            MinHeight="190"
                            Padding="0"
                            CornerRadius="18"
                            Background="#F8FAFF"
                            BorderBrush="#ECF0F8"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBox Padding="14"
                                     Background="#00FFFFFF"
                                     BorderThickness="0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Disabled"
                                     IsEnabled="{Binding IsEditing}"
                                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
